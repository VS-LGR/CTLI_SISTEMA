# Copy to `.env.local` (gitignored) and fill in from Supabase → Settings → API.
# CRA only reads env files at dev/build start — restart `npm start` after changes.

REACT_APP_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use one of the following (dashboard may show only “publishable” key):
# REACT_APP_SUPABASE_ANON_KEY=eyJ...
REACT_APP_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
